@page "/admin/blogs"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout MainAdminLayout
@inject IBlogService BlogService 
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<div class="min-h-screen bg-slate-50 p-4">
    @if (!showForm)
    {
        <div class="mb-6 flex items-center justify-between">
            <h1 class="text-2xl font-bold text-slate-800">Quản lý Bài viết</h1>
            <button @onclick="ShowAddForm" class="rounded-lg bg-indigo-600 px-4 py-2 font-medium text-white shadow-sm transition hover:bg-indigo-700">
                + Viết bài mới
            </button>
        </div>

        <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
            <table class="w-full border-collapse text-left">
                <thead class="border-b border-slate-200 bg-slate-100 text-sm text-slate-600">
                    <tr>
                        <th class="p-4 font-semibold">Bài viết</th>
                        <th class="p-4 font-semibold">Danh mục</th>
                        <th class="p-4 font-semibold">Tác giả</th>
                        <th class="p-4 font-semibold">Trạng thái</th>
                        <th class="p-4 text-right font-semibold">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (blogs == null)
                    {
                        <tr><td colspan="5" class="p-4 text-center text-slate-500">Đang tải dữ liệu...</td></tr>
                    }
                    else if (!blogs.Any())
                    {
                        <tr><td colspan="5" class="p-4 text-center text-slate-500">Chưa có bài viết nào.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in blogs)
                        {
                            <tr class="transition hover:bg-slate-50">
                                <td class="p-4">
                                    <div class="flex items-center gap-3">
                                        @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                                        {
                                            <img src="@item.CoverImageUrl" class="h-12 w-16 rounded object-cover shadow-sm" />
                                        }
                                        <div>
                                            <p class="line-clamp-1 font-medium text-slate-800">@item.Title</p>
                                            <p class="text-xs text-slate-500">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-4 text-sm text-slate-600">@item.Category</td>
                                <td class="p-4 text-sm text-slate-600">@item.Author</td>
                                <td class="p-4">
                                    <span class="rounded-full px-2 py-1 text-xs font-medium @(item.IsPublished ? "bg-green-100 text-green-700" : "bg-slate-100 text-slate-600")">
                                        @(item.IsPublished ? "Đã xuất bản" : "Bản nháp")
                                    </span>
                                </td>
                                <td class="space-x-2 p-4 text-right">
                                    <button @onclick="() => ShowEditForm(item)" class="text-blue-600 hover:text-blue-800 px-2 font-medium">Sửa</button>
                                    <button @onclick="() => DeleteBlog(item.Id)" class="text-red-600 hover:text-red-800 px-2 font-medium">Xóa</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="mx-auto max-w-6xl">
            <div class="mb-6 flex items-center justify-between">
                <h1 class="text-2xl font-bold text-slate-800">@(currentBlog.Id == 0 ? "Thêm bài viết mới" : "Chỉnh sửa bài viết")</h1>
                <button @onclick="HideForm" class="font-medium text-slate-500 transition hover:text-slate-800">
                    ← Quay lại
                </button>
            </div>

            <EditForm Model="currentBlog" OnValidSubmit="HandleValidSubmit" class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <DataAnnotationsValidator />

                <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
                    
                    <div class="space-y-4 lg:col-span-2">
                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Tiêu đề <span class="text-red-500">*</span></label>
                            <InputText @bind-Value="currentBlog.Title" @onblur="GenerateSlug" class="w-full rounded-lg border border-slate-300 px-4 py-2 outline-none focus:ring-2 focus:ring-indigo-500" placeholder="Nhập tiêu đề..." />
                            <ValidationMessage For="@(() => currentBlog.Title)" class="text-red-500 text-sm mt-1" />
                        </div>

                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Đường dẫn (Slug) <span class="text-red-500">*</span></label>
                            <InputText @bind-Value="currentBlog.Slug" class="w-full rounded-lg border border-slate-300 bg-slate-50 px-4 py-2 text-slate-500 outline-none" />
                            <ValidationMessage For="@(() => currentBlog.Slug)" class="text-red-500 text-sm mt-1" />
                        </div>

                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Tóm tắt</label>
                            <InputTextArea @bind-Value="currentBlog.Summary" rows="3" class="w-full rounded-lg border border-slate-300 px-4 py-2 outline-none focus:ring-2 focus:ring-indigo-500" />
                        </div>

                        <div class="flex h-[600px] flex-col">
                            <label class="mb-1 block text-sm font-medium text-slate-700">Nội dung <span class="text-red-500">*</span></label>
                            <div class="relative flex flex-1 flex-col overflow-hidden rounded-lg border border-slate-300 bg-white focus-within:border-indigo-500 focus-within:ring-2 focus-within:ring-indigo-500">
                                
                                <RichTextEditor @bind-Content="currentBlog.Content" Placeholder="Nhập nội dung bài viết..." />
                                
                            </div>
                            <ValidationMessage For="@(() => currentBlog.Content)" class="text-red-500 text-sm mt-1" />
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
                            <label class="flex cursor-pointer items-center gap-2">
                                <InputCheckbox @bind-Value="currentBlog.IsPublished" class="h-5 w-5 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" />
                                <span class="font-medium text-slate-700">Xuất bản ngay</span>
                            </label>
                        </div>

                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Ảnh đại diện (URL)</label>
                            <InputText @bind-Value="currentBlog.CoverImageUrl" class="w-full rounded-lg border border-slate-300 px-4 py-2 outline-none focus:ring-2 focus:ring-indigo-500" />
                            @if (!string.IsNullOrEmpty(currentBlog.CoverImageUrl))
                            {
                                <img src="@currentBlog.CoverImageUrl" class="mt-2 h-32 w-full rounded-lg border border-slate-200 object-cover" />
                            }
                        </div>

                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Danh mục</label>
                            <InputText @bind-Value="currentBlog.Category" class="w-full rounded-lg border border-slate-300 px-4 py-2 outline-none focus:ring-2 focus:ring-indigo-500" placeholder="VD: Tin tức, Công nghệ..." />
                        </div>

                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Tác giả</label>
                            <InputText @bind-Value="currentBlog.Author" class="w-full rounded-lg border border-slate-300 px-4 py-2 outline-none focus:ring-2 focus:ring-indigo-500" />
                        </div>

                        <hr class="border-slate-200" />

                        <h3 class="font-semibold text-slate-800">Cài đặt SEO</h3>
                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Thẻ Tags (cách nhau dấu phẩy)</label>
                            <InputText @bind-Value="currentBlog.Tags" class="w-full rounded-lg border border-slate-300 px-4 py-2 outline-none focus:ring-2 focus:ring-indigo-500" placeholder="seo, blog, tailwind..." />
                        </div>
                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Meta Description</label>
                            <InputTextArea @bind-Value="currentBlog.MetaDescription" rows="4" class="w-full rounded-lg border border-slate-300 px-4 py-2 outline-none focus:ring-2 focus:ring-indigo-500" />
                        </div>
                    </div>
                </div>

                <div class="mt-8 flex justify-end gap-3 border-t border-slate-200 pt-6">
                    <button type="button" @onclick="HideForm" class="rounded-lg border border-slate-300 px-6 py-2 font-medium text-slate-700 transition hover:bg-slate-50">
                        Hủy
                    </button>
                    <button type="submit" class="rounded-lg bg-indigo-600 px-6 py-2 font-medium text-white shadow-md shadow-indigo-200 transition hover:bg-indigo-700">
                        Lưu bài viết
                    </button>
                </div>
            </EditForm>
        </div>
    }
</div>

<style>
    .ql-toolbar.ql-snow {
        border: none !important;
        border-bottom: 1px solid #e2e8f0 !important;
        background-color: #f8fafc;
        border-top-left-radius: 0.5rem;
        border-top-right-radius: 0.5rem;
    }
    .ql-container.ql-snow {
        border: none !important;
        flex-grow: 1;
        overflow-y: auto;
        font-family: inherit;
        background-color: white;
        border-bottom-left-radius: 0.5rem;
        border-bottom-right-radius: 0.5rem;
    }
    .ql-editor {
        min-height: 500px;
        font-size: 1rem;
        color: #334155;
    }
</style>

@code {
    private IEnumerable<Blog>? blogs;
    private Blog currentBlog = new Blog();
    private bool showForm = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadBlogs();
    }

    private async Task LoadBlogs()
    {
        blogs = await BlogService.GetAllAsync();
    }

    private void ShowAddForm()
    {
        currentBlog = new Blog 
        { 
            Author = "Lưu Văn", 
            IsPublished = true,
            CreatedAt = DateTime.UtcNow 
        };
        showForm = true;
    }

    private void ShowEditForm(Blog blog)
    {
        currentBlog = new Blog
        {
            Id = blog.Id,
            Title = blog.Title,
            Slug = blog.Slug,
            Summary = blog.Summary,
            Content = blog.Content,
            CoverImageUrl = blog.CoverImageUrl,
            Author = blog.Author,
            IsPublished = blog.IsPublished,
            Category = blog.Category,
            Tags = blog.Tags,
            MetaDescription = blog.MetaDescription,
            CreatedAt = blog.CreatedAt, 
            ViewCount = blog.ViewCount 
        };
        showForm = true;
    }

    private void HideForm()
    {
        showForm = false;
    }

    private async Task HandleValidSubmit()
    {
        if (currentBlog.Id == 0)
        {
            currentBlog.CreatedAt = DateTime.UtcNow;
            await BlogService.CreateAsync(currentBlog);
        }
        else
        {
            currentBlog.UpdatedAt = DateTime.UtcNow;
            await BlogService.UpdateAsync(currentBlog);
        }

        await LoadBlogs();
        showForm = false;
        StateHasChanged(); 
    }

    private async Task DeleteBlog(int id)
    {
        var result = await BlogService.DeleteAsync(id);
        if (result)
        {
            await LoadBlogs();
            StateHasChanged(); 
        }
    }

    private void GenerateSlug()
    {
        if (!string.IsNullOrWhiteSpace(currentBlog.Title) && string.IsNullOrWhiteSpace(currentBlog.Slug))
        {
            currentBlog.Slug = currentBlog.Title.ToLower()
                .Replace(" ", "-")
                .Replace("đ", "d")
                .Replace("á", "a").Replace("à", "a").Replace("ả", "a").Replace("ã", "a").Replace("ạ", "a")
                .Replace("é", "e").Replace("è", "e").Replace("ẻ", "e").Replace("ẽ", "e").Replace("ẹ", "e")
                .Replace("í", "i").Replace("ì", "i").Replace("ỉ", "i").Replace("ĩ", "i").Replace("ị", "i")
                .Replace("ó", "o").Replace("ò", "o").Replace("ỏ", "o").Replace("õ", "o").Replace("ọ", "o")
                .Replace("ô", "o").Replace("ố", "o").Replace("ồ", "o").Replace("ổ", "o").Replace("ỗ", "o").Replace("ộ", "o")
                .Replace("ơ", "o").Replace("ớ", "o").Replace("ờ", "o").Replace("ở", "o").Replace("ỡ", "o").Replace("ợ", "o")
                .Replace("ú", "u").Replace("ù", "u").Replace("ủ", "u").Replace("ũ", "u").Replace("ụ", "u")
                .Replace("ư", "u").Replace("ứ", "u").Replace("ừ", "u").Replace("ử", "u").Replace("ữ", "u").Replace("ự", "u")
                .Replace("ý", "y").Replace("ỳ", "y").Replace("ỷ", "y").Replace("ỹ", "y").Replace("ỵ", "y")
                + "-" + DateTime.Now.Ticks.ToString().Substring(10); 
        }
    }
}