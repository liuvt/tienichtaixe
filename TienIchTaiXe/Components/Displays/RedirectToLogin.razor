@inject NavigationManager Nav

@code {
    protected override void OnInitialized()
    {
        // Dùng Nav.ToBaseRelativePath để lấy phần đường dẫn sau domain, sau đó mã hóa nó để tránh lỗi khi có ký tự đặc biệt
        var returnUrl = Uri.EscapeDataString(Nav.ToBaseRelativePath(Nav.Uri));
        Nav.NavigateTo($"/sign-in?returnUrl=/", forceLoad: true);
    }
}
