@rendermode @(new InteractiveServerRenderMode(prerender: true))
@inject IJSRuntime JS

<div class="py-4">
    <!-- Trigger button -->
    <button type="button"
            class="inline-flex w-full items-center justify-center rounded-xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-600 disabled:cursor-not-allowed disabled:opacity-60"
            @onclick="Open">
        Đăng ký nhận thông báo zalo
    </button>

    @if (IsOpen)
    {
        <!-- Overlay -->
        <div class="fixed inset-0 z-[9999]">
            <!-- Backdrop (click to close) -->
            <div class="absolute inset-0 bg-black/50" @onclick="Close" aria-hidden="true"></div>

            <!-- Panel -->
            <div class="absolute inset-x-0 bottom-0 md:inset-0 md:flex md:items-center md:justify-center">
                <div class="max-h-[85vh] w-full overflow-hidden rounded-t-2xl bg-white p-4 shadow-2xl md:w-[520px] md:max-w-[92vw] md:rounded-2xl md:p-6"
                     role="dialog"
                     aria-modal="true"
                     aria-labelledby="dialogTitle"
                     @onclick:stopPropagation="true">

                    <!-- Header -->
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <h2 id="dialogTitle" class="text-base font-semibold text-slate-900 uppercase md:text-lg">
                                Đăng ký nhận tin
                            </h2>
                            <p class="mt-1 text-xs text-slate-500 md:text-sm">
                                Nhập biển số xe và số điện thoại để gửi yêu cầu. Hãy đảm bảo bạn đã kết nối Zalo với số điện thoại này.
                            </p>
                        </div>

                        <button type="button"
                                class="rounded-xl p-2 text-slate-500 hover:bg-slate-100 hover:text-slate-700"
                                @onclick="Close"
                                aria-label="Đóng">
                            ✕
                        </button>
                    </div>

                    <!-- ✅ Scroll area -->
                    <div class="mt-4 overflow-y-auto overscroll-contain pr-1">
                        <EditForm Model="@notification" OnSubmit="OnSubmitAsync">
                            <div class="space-y-4">

                                <!-- Plate -->
                                <div class="mb-4">
                                    <label for="plateInput"
                                           class="mb-1 block font-medium tracking-wide text-[11px] uppercase">
                                        Biển số xe
                                    </label>

                                    <div class="flex items-stretch rounded-xl border border-slate-200 bg-white shadow-sm focus-within:border-pink-500 focus-within:ring-2 focus-within:ring-pink-500/60">
                                        <span class="flex items-center px-4 text-base">
                                            <span class="text-slate-400">🚗</span>
                                        </span>

                                        <input id="plateInput"
                                               @bind="notification.Plate"
                                               class="w-full rounded-r-xl border-0 bg-transparent px-2 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:ring-0 focus:outline-none"
                                               autocomplete="off"
                                               placeholder="Ví dụ: 83F00101" />
                                    </div>
                                    <p class="mt-1 text-xs text-slate-500">
                                        Hỗ trợ dạng: 83F-001.01
                                    </p>
                                </div>

                                <!-- Phone -->
                                <div class="mb-4">
                                    <label for="telInput"
                                           class="mb-1 block font-medium tracking-wide text-[11px] uppercase">
                                        Số điện thoại
                                    </label>

                                    <div class="flex items-stretch rounded-xl border border-slate-200 bg-white shadow-sm focus-within:border-pink-500 focus-within:ring-2 focus-within:ring-pink-500/60">
                                        <span class="flex items-center px-4 text-base">
                                            <span class="text-slate-400">☎️</span>
                                        </span>

                                        <input id="telInput" type="tel"
                                               @bind="notification.PhoneNumber"
                                               class="w-full rounded-r-xl border-0 bg-transparent px-2 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:ring-0 focus:outline-none"
                                               placeholder="Ví dụ: 0986812586" autocomplete="tel" />
                                    </div>
                                    <p class="mt-1 text-xs text-slate-500">
                                        Hỗ trợ dạng: 0986.812.586
                                    </p>
                                </div>

                                <!-- Message -->
                                @if (!string.IsNullOrWhiteSpace(Message))
                                {
                                    <div class="text-sm @(IsError ? "text-red-600" : "text-emerald-600")">
                                        @Message
                                    </div>
                                }

                                <!-- Actions -->
                                <div class="flex gap-2 pt-1">
                                    <button type="button"
                                            class="w-1/3 rounded-xl border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-700 uppercase hover:bg-slate-50"
                                            @onclick="Close"
                                            disabled="@IsSubmitting">
                                        Hủy
                                    </button>

                                    <button type="submit"
                                            class="w-2/3 rounded-xl bg-slate-900 px-3 py-2 text-sm font-semibold text-white uppercase hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
                                            disabled="@IsSubmitting">
                                        @(IsSubmitting ? "Đang đăng ký..." : "Đăng ký")
                                    </button>
                                </div>
                            </div>
                        </EditForm>
                    </div>

                </div>
            </div>
        </div>
    }
</div>

@code {
    // C# code can be added here if needed in the future
    //https://n8n.taxinamthang.vn/webhook/dang_ky_nhan_tin
    [Inject]
    private INotificationServices notificationServices { get; set; } = default!;
    private string errorMessage { get; set; } = string.Empty;
    private GGNotification notification { get; set; } = new GGNotification();
    private bool IsOpen;
    private bool IsSubmitting;
    private string Message = "";
    private bool IsError;

    private async Task Open()
    {
        Message = "";
        IsError = false;
        IsOpen = true;

        // khóa scroll nền + disable footer (nếu có)
        await JS.InvokeVoidAsync("tvtModal.lock", true);
    }

    private async Task Close()
    {
        IsOpen = false;
        await JS.InvokeVoidAsync("tvtModal.lock", false);
    }

    private static string NormalizePlate(string s)
        => (s ?? "").ToUpperInvariant().Replace(" ", "").Replace(".", "").Replace("-", "");

    private static string NormalizePhone(string s)
        => (s ?? "").Replace(" ", "").Replace(".", "").Replace("-", "");

    private async Task OnSubmitAsync()
    {
        try
        {
            IsSubmitting = true;
            Message = "";
            IsError = false;

            notification.Plate = NormalizePlate(notification.Plate);
            notification.PhoneNumber = NormalizePhone(notification.PhoneNumber);

            if (string.IsNullOrWhiteSpace(notification.Plate) || string.IsNullOrWhiteSpace(notification.PhoneNumber))
                throw new Exception("Vui lòng nhập đầy đủ biển số xe và số điện thoại.");

            await notificationServices.PostGGNotification(notification);

            Message = "Đăng ký nhận thông báo phạt nguội thành công!";
            IsError = false;

            // reset + đóng dialog (nếu bạn muốn giữ dialog mở thì bỏ Close)
            notification = new GGNotification();
            await Close();
        }
        catch (Exception ex)
        {
            IsError = true;
            Message = ex.Message; // hoặc message chung nếu bạn muốn
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
