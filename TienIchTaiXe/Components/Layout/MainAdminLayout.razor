@inherits LayoutComponentBase

<div class="flex h-screen bg-slate-50 font-sans text-slate-800">

    @if (isSidebarOpen)
    {
        <div class="fixed inset-0 z-40 bg-slate-900/50 backdrop-blur-sm md:hidden" @onclick="ToggleSidebar"></div>
    }

    <aside class="@(isSidebarOpen ? "translate-x-0" : "-translate-x-full") fixed inset-y-0 left-0 z-50 flex w-64 flex-col bg-slate-900 transition-transform duration-300 ease-in-out md:static md:translate-x-0">
        <div class="flex h-16 items-center justify-center border-b border-slate-800 bg-slate-950 px-6">
            <span class="text-xl font-bold tracking-wider text-white">ADMIN<span class="text-indigo-500">PANEL</span></span>
        </div>

        <nav class="flex-1 space-y-1 overflow-y-auto px-3 py-4">
            
            <p class="mb-2 px-3 text-xs font-semibold tracking-wider text-slate-500 uppercase">Menu chính</p>
            
            <NavLink href="/admin/dashboard" class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800 hover:text-white" ActiveClass="bg-indigo-600 text-white hover:bg-indigo-600">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Tổng quan
            </NavLink>

            <NavLink href="/admin/blogs" class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800 hover:text-white" ActiveClass="bg-indigo-600 text-white hover:bg-indigo-600">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H14" />
                </svg>
                Quản lý Blog
            </NavLink>

            <NavLink href="/admin/categories" class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800 hover:text-white" ActiveClass="bg-indigo-600 text-white hover:bg-indigo-600">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                </svg>
                Quản lý Danh mục
            </NavLink>

            <NavLink href="/admin/users" class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800 hover:text-white" ActiveClass="bg-indigo-600 text-white hover:bg-indigo-600">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                Quản lý User
            </NavLink>
        </nav>

        <div class="border-t border-slate-800 p-4">
            <button class="flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-400 transition-colors hover:bg-red-500/10 hover:text-red-500">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                Đăng xuất
            </button>
        </div>
    </aside>

    <div class="flex flex-1 flex-col overflow-hidden">
        
        <header class="flex h-16 items-center justify-between border-b border-slate-200 bg-white px-4 shadow-sm md:px-6">
            <button @onclick="ToggleSidebar" class="rounded-md p-2 text-slate-500 hover:bg-slate-100 hover:text-slate-700 md:hidden">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>

            <div class="flex-1"></div>

            <div class="flex items-center gap-3">
                <div class="hidden text-right md:block">
                    <p class="text-sm font-semibold text-slate-700">Lưu Văn</p>
                    <p class="text-xs text-slate-500">Administrator</p>
                </div>
                <img src="https://ui-avatars.com/api/?name=Lưu+Văn&background=4f46e5&color=fff" alt="Avatar" class="h-9 w-9 rounded-full shadow-sm" />
            </div>
        </header>

        <main class="flex-1 overflow-x-hidden overflow-y-auto bg-slate-50 p-4 md:p-6 lg:p-8">
            <div class="mx-auto max-w-7xl">
                @Body
            </div>
        </main>
        
    </div>
</div>

@code {
    private bool isSidebarOpen = false;

    // Hàm dùng để đóng/mở sidebar trên màn hình điện thoại
    private void ToggleSidebar()
    {
        isSidebarOpen = !isSidebarOpen;
    }
}